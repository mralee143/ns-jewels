# PostgreSQL — use either a single URL or split fields (split wins when DB_HOST, DB_USER, and DB_NAME are all set).
# To use only DATABASE_URL, leave DB_HOST / DB_USER / DB_NAME empty or remove those lines.
#
# Local dev (app on host, Postgres via docker compose):
DATABASE_URL="postgresql://nsjewels:ns-app@localhost:5432/ns-jewels"

DB_HOST=localhost
DB_PORT=5432
DB_USER=nsjewels
DB_PASSWORD=ns-app
DB_NAME=ns-jewels

# Docker / production (app container on same network as Postgres):
# Do NOT use localhost — use the Postgres *service* hostname (Dokploy/Coolify often prefixes the project, e.g. websites_ns-db).
# DB_HOST=websites_ns-db
# DB_PORT=5432
# DB_USER=nsjewels
# DB_PASSWORD=ns-app
# DB_NAME=ns-jewels

# Auth.js / NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=""
# Production site URL — set on the server (fixes sign-out when not using 0.0.0.0 in the browser).
AUTH_URL="https://nsjewelspk.com"
NEXT_PUBLIC_SITE_URL="https://nsjewelspk.com"

# Optional Google OAuth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# SMTP (transactional email — Gmail needs an App Password, not your login password)
# For local `next start` (production) without real SMTP, set: SIGNUP_OTP_CONSOLE_FALLBACK="true"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""

# Order notification emails
ADMIN_ORDER_EMAIL=""

# When "true", if sending fails (or Gmail has no user/pass), the OTP is printed in the **server** log
# and sign-up still succeeds. Use for local production builds; do not use on a public server.
SIGNUP_OTP_CONSOLE_FALLBACK=""

# Same fallback behavior for customer/admin order emails.
ORDER_EMAIL_CONSOLE_FALLBACK=""

# One-time admin bootstrap (run: npm run db:seed)
ADMIN_SEED_EMAIL=""
ADMIN_SEED_PASSWORD=""
ADMIN_SEED_NAME="Ali Haider"

# Docker: keep ENTRYPOINT enabled so `prisma migrate deploy` runs on start. Set RUN_MIGRATIONS=false only if you migrate manually.
# RUN_MIGRATIONS=true

# HTTP server (used by npm run dev / start and Docker standalone server.js)
PORT=3000
HOSTNAME=0.0.0.0

# deploy.sh — Docker Hub PAT (never commit; export locally or use CI secrets)
# DOCKER_PASSWORD=""
